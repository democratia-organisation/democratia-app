<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="com.democratia.Views.internaute.gestionCompte.ModifierGestionPage"
             xmlns:component="clr-namespace:com.democratia.Views.Component"
             xmlns:viewModel="clr-namespace:com.democratia.ViewModels.internaute.gestionCompte;assembly=com.democratia.core"
             xmlns:lang="clr-namespace:com.democratia.view.Resources.Localization"
             x:DataType="viewModel:ModifierGestionViewModel"
             Style="{DynamicResource fondEcran}"
             Title="ModifierGestionPage">

    <ScrollView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <component:Header Grid.Row="0"/>
<!--REFACTO : créer un content view qui aura comme contexte une Iterface comme context et chaque ViewModel qui l'utilise devra implémenter ce viewModel-->
            <StackLayout Padding="10" Grid.Row="1" x:Name="stackLayout">
                <BoxView HeightRequest="50"/>
                <component:EntryComponent Title="{x:Static lang:AppResources.Nom}" x:Name="nomDeFamilleComponent" ValeurDonne="{Binding TempInternaute.nom_internaute}"/>
                <component:EntryComponent Title="{x:Static lang:AppResources.prenom}" x:Name="prenomComponent" ValeurDonne="{Binding TempInternaute.prenom_internaute}"/>
                <component:EntryComponent Title="{x:Static lang:AppResources.adress}" x:Name="addresseComponent" ValeurDonne="{Binding TempInternaute.adresse_postale}"/>
                <component:EntryComponent Title="{x:Static lang:AppResources.mail}" x:Name="mailComponent" ValeurDonne="{Binding TempInternaute.courriel}"/>
                <component:EntryComponent Title="{x:Static lang:AppResources.Mdp}" PassWord="True" x:Name="passwordComponent" ValeurDonne="{Binding TempInternaute.hashageMDP}"/>
                <Label Text="{Binding RetourMessage}" Style="{DynamicResource ErrorLabelStyle}" HorizontalOptions="Center" x:Name="retourMessageLabel" AutomationId="RetourMessage"/>
                <BoxView HeightRequest="100"/>
                <Button
                    Text="{x:Static lang:AppResources.enregistrer}"
                    x:Name="inscriptionButton"
                    Style="{DynamicResource ButtonStyle}"
                    Command="{Binding ModifierInternauteCommand}"
                    AutomationId="M'inscrire"
                    AutomationProperties.Name="M'inscrire"
                />
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>