<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="com.democratia.Views.internaute.gestionCompte.CreationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.democratia.Views.Component"
    xmlns:lang="clr-namespace:com.democratia.view.Resources.Localization"
    xmlns:local="clr-namespace:com.democratia.Views"
    xmlns:viewModel="clr-namespace:com.democratia.ViewModels.internaute.gestionCompte;assembly=com.democratia.core"
    x:DataType="viewModel:CreationViewModel"
    AutomationId="creationPage     "
    Style="{DynamicResource fondEcran}">

    <ScrollView>
        <Grid x:Name="mainGrille">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <component:Header
                x:Name="header"
                Grid.Row="0"
                AutomationId="header" />

            <StackLayout
                x:Name="stackLayout"
                Grid.Row="1"
                Padding="10"
                AutomationId="stackLayout">
                <BoxView HeightRequest="{StaticResource SpacingLarge}" />
                <component:EntryComponent
                    x:Name="nomDeFamilleEntryComponent"
                    Title="{x:Static lang:AppResources.Nom}"
                    AutomationId="nomDeFamilleEntryComponent"
                    ValeurDonne="{Binding Internaute.nom_internaute}" />
                <component:EntryComponent
                    x:Name="prenomEntryComponent"
                    Title="{x:Static lang:AppResources.prenom}"
                    AutomationId="prenomEntryComponent"
                    ValeurDonne="{Binding Internaute.prenom_internaute}" />
                <component:EntryComponent
                    x:Name="addresseEntryComponent"
                    Title="{x:Static lang:AppResources.adress}"
                    AutomationId="addresseEntryComponent"
                    ValeurDonne="{Binding Internaute.adresse_postale}" />
                <component:EntryComponent
                    x:Name="mailEntryComponent"
                    Title="{x:Static lang:AppResources.mail}"
                    AutomationId="mailEntryComponent"
                    ValeurDonne="{Binding Email}" />
                <component:EntryComponent
                    x:Name="passwordEntryComponent"
                    Title="{x:Static lang:AppResources.Mdp}"
                    AutomationId="passwordEntryComponent"
                    PassWord="True"
                    ValeurDonne="{Binding Password}" />
                <Label
                    x:Name="retourMessageLabel"
                    AutomationId="retourMessageLabel"
                    HorizontalOptions="Center"
                    Style="{DynamicResource ErrorLabelStyle}"
                    Text="{Binding RetourMessage}" />
                <BoxView HeightRequest="{DynamicResource SpacingExtraLarge}" />
                <Button
                    x:Name="inscriptionButton"
                    AutomationId="inscriptionButton"
                    Command="{Binding CreerInternauteTappedCommand}"
                    Style="{DynamicResource ButtonStyle}"
                    Text="{x:Static lang:AppResources.inscription}" />
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
