<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:com.democratia.Views"
             xmlns:component="clr-namespace:com.democratia.Views.Component"
             xmlns:viewModel="clr-namespace:com.democratia.ViewModels;assembly=com.democratia.core"
             x:Class="com.democratia.Views.GestionCompte"
             x:DataType="viewModel:GestionCompteViewModel"
             Style="{DynamicResource fondEcran}"
             >

    <ScrollView>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <component:Header Grid.Row="0"/>

            <StackLayout Padding="10" Grid.Row="1" x:Name="stackLayout">
                <BoxView HeightRequest="50"/>

                <Label Text="{Binding RetourMessage}" Style="{DynamicResource ErrorLabelStyle}" HorizontalOptions="Center" x:Name="retourMessageLabel"/>
                <BoxView HeightRequest="100"/>
                <Button
                    Text="Modifier Mon Compte"
                    x:Name="modificationnButton"
                    Style="{DynamicResource ButtonStyle}"
                    Command="{Binding ActionInternauteCommand}"
                    CommandParameter="Modif"
                    AutomationId="modificationnButton"
                    AutomationProperties.Name="modificationnButton"
                />
                <BoxView HeightRequest="100"/>
                <Button
                    Text="Supprimer Mon Compte"
                    x:Name="suppresionButton"
                    Style="{DynamicResource ButtonStyle}"
                    Command="{Binding ActionInternauteCommand}"
                    CommandParameter="Supp"
                    AutomationId="suppresionButton"
                    AutomationProperties.Name="suppresionButton"
                />
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>