<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="com.democratia.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.democratia.Views.Component"
    xmlns:converters="clr-namespace:com.democratia.Utils;assembly=com.democratia.core"
    xmlns:lang="clr-namespace:com.democratia.view.Resources.Localization"
    xmlns:local="clr-namespace:com.democratia.Views"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModels="clr-namespace:com.democratia.ViewModels.internaute;assembly=com.democratia.core"
    x:DataType="viewModels:MainViewModel"
    AutomationId="connexionPage"
    Style="{DynamicResource fondEcran}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>


    <ScrollView>
        <Grid x:Name="mainGrille" AutomationId="mainGrille">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <component:Header
                x:Name="header"
                Grid.Row="0"
                AutomationId="header" />

            <VerticalStackLayout Grid.Row="1" Spacing="{DynamicResource SpacingMedium}">

                <Label
                    x:Name="connexionLabel"
                    AutomationId="connexionLabel"
                    HorizontalOptions="Center"
                    Style="{DynamicResource HeadlineStyle}"
                    Text="{x:Static lang:AppResources.Identifiant}" />

                <component:EntryComponent
                    x:Name="mailEntryComponent"
                    Title="{x:Static lang:AppResources.mail}"
                    AutomationId="mailEntryComponent"
                    ValeurDonne="{Binding AdresseMail}" />

                <component:EntryComponent
                    x:Name="passwordEntryComponent"
                    Title="{x:Static lang:AppResources.Mdp}"
                    AutomationId="passwordEntryComponent"
                    PassWord="True"
                    ValeurDonne="{Binding MotDePasse}" />

                <Label
                    x:Name="errorMessageLabel"
                    AutomationId="errorMessageLabel"
                    HorizontalOptions="Center"
                    Style="{DynamicResource ErrorLabelStyle}"
                    Text="{Binding ErrorMessage}" />

                <HorizontalStackLayout
                    HorizontalOptions="Center"
                    Spacing="30"
                    VerticalOptions="End">
                    <Label
                        x:Name="pasDeCompteLabel"
                        AutomationId="pasDeCompteLabel"
                        HorizontalOptions="Center"
                        Style="{DynamicResource LabelStyle}"
                        Text="{x:Static lang:AppResources.pasCompte}" />

                    <Label
                        x:Name="creerCompteLabel"
                        AutomationId="creerCompteLabel"
                        HorizontalOptions="Center"
                        Style="{DynamicResource LabelStyle}"
                        Text="{x:Static lang:AppResources.NewCompte}"
                        TextColor="{AppThemeBinding Light={DynamicResource Light-tertiary},
                                                    Dark={DynamicResource Dark-tertiary}}"
                        TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateTappedCommand}" CommandParameter="CreationPage" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

                <Button
                    x:Name="seConnecterButton"
                    AutomationId="seConnecterButton"
                    Command="{Binding NavigateTappedCommand}"
                    CommandParameter="/HomePage"
                    Style="{DynamicResource ButtonStyle}"
                    Text="{x:Static lang:AppResources.connecter}"
                    VerticalOptions="End" />
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
