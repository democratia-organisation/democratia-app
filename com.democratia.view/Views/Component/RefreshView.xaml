<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.democratia.Views.Component.RefreshView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">
    <Grid RowDefinitions="*">
        <RefreshView
            x:Name="refreshView"
            Grid.Row="0"
            AutomationId="refreshView"
            Command="{Binding ChargerElementsCommand, Source={x:Reference this}}"
            IsRefreshing="{Binding IsRefreshing, Source={x:Reference this}}"
            VerticalOptions="Fill">
            <CollectionView
                x:Name="elementsCollectionView"
                AutomationId="elementsCollectionView"
                HorizontalOptions="Center"
                ItemTemplate="{Binding ItemTemplate, Source={x:Reference this}}"
                ItemsSource="{Binding Elements, Source={x:Reference this}}"
                RemainingItemsThreshold="1"
                RemainingItemsThresholdReachedCommand="{Binding UpdateElementsCommand, Source={x:Reference this}}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout ItemSpacing="{DynamicResource SpacingSmall}" Orientation="Vertical" />
                </CollectionView.ItemsLayout>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentView>
