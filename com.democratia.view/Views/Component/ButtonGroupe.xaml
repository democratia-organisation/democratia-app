<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.democratia.Views.Component.ButtonGroupe"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModel="clr-namespace:com.democratia.ViewModels.groupe;assembly=com.democratia.core"
    x:Name="this"
    x:DataType="viewModel:GroupeViewModel"
    Style="{StaticResource ContenViewStyle}">

    <Border
        MaximumHeightRequest="{StaticResource SpacingUltraLarge}"
        MaximumWidthRequest="{StaticResource SpacingUltraLarge}"
        Style="{StaticResource BorderStyleButton}">

        <VerticalStackLayout>
            <ImageButton
                AutomationId="{Binding Groupe.NomGroupe, Source={x:Reference this}, StringFormat='{0}button'}"
                Command="{Binding OpenGroupCommand}"
                CommandParameter="{Binding Groupe.NomGroupe}"
                HeightRequest="{StaticResource SpacingUltraLarge}"
                HorizontalOptions="Center"
                Source="{Binding Image}"
                WidthRequest="{StaticResource SpacingUltraLarge}" />

            <Label
                HorizontalOptions="Center"
                LineBreakMode="WordWrap"
                Style="{StaticResource SubHeadlineStyle}"
                Text="{Binding Groupe.NomGroupe, Source={x:Reference this}}" />
        </VerticalStackLayout>

    </Border>
</ContentView>