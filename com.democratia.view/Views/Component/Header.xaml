<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:com.democratia.Views.Component"
             x:Class="com.democratia.Views.Component.Header"
             xmlns:lang="clr-namespace:com.democratia.view.Resources.Localization"
             BackgroundColor="{AppThemeBinding Dark={DynamicResource Dark-surfaceContainer}, Light={DynamicResource Light-surfaceContainer}}"
             
             >
    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- En haut à gauche -->
        <ImageButton
            x:Name="backButton"
            Source="back.png"
            Style="{DynamicResource ImageButtonStyle}"
            HorizontalOptions="Start"
            VerticalOptions="Center"
            MaximumHeightRequest="50"
            MaximumWidthRequest="50"
            Clicked="OnClicked"
            Grid.Column="0"
            AutomationId="BackButton"
        />
        <ImageButton
            Source="logo.png"
            x:Name="logoImage"
            MaximumWidthRequest="60"
            MaximumHeightRequest="60"
            HorizontalOptions="Center"
            Grid.Column="1"
            Clicked="OnClicked"
            AutomationId="LogoImage"/>
        <!--<HorizontalStackLayout Grid.Column="1">
            <ImageButton
                Source="logo.png"
                x:Name="logoImage"
                MaximumWidthRequest="60"
                MaximumHeightRequest="60"
                HorizontalOptions="Center"
                Grid.Column="1"
                Clicked="OnClicked"
                AutomationId="LogoImage"/>
            <Picker x:Name="languagePicker"
                    SelectedIndexChanged="OnClicked"
                    Title="{x:Static lang:AppResources.Langage}"
                    Style="{DynamicResource PickerStyle}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>FR</x:String>
                        <x:String>EN</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
        </HorizontalStackLayout> -->
        <!-- En haut à droite -->
        <ImageButton
            Source="light.png"
            x:Name="switchImageButton"
            Style="{DynamicResource ImageButtonStyle}"
            MaximumWidthRequest="50"
            MaximumHeightRequest="50"
            HorizontalOptions="End"
            VerticalOptions="Center"
            Clicked="OnClicked"
            Grid.Column="2"
            AutomationId="SwitchImageButton"
        />
    </Grid>

</ContentView>
