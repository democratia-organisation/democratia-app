<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.democratia.Views.Component.PropositionCard"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:lang="clr-namespace:com.democratia.view.Resources.Localization"
    xmlns:models="clr-namespace:com.democratia.Models;assembly=com.democratia.core"
    xmlns:viewModels="clr-namespace:com.democratia.ViewModels.groupe;assembly=com.democratia.core"
    x:DataType="models:Proposition"
    Style="{DynamicResource ContenViewStyle}">
    <VerticalStackLayout>
        <HorizontalStackLayout Spacing="{DynamicResource SpacingLarge}">
            <Label
                x:Name="titreLabel"
                x:DataType="models:Proposition"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                Style="{DynamicResource LabelStyle}"
                Text="{Binding Titre}" />
            <Image
                HeightRequest="30"
                HorizontalOptions="End"
                Source="loupe.png"
                VerticalOptions="End"
                WidthRequest="30" />
        </HorizontalStackLayout>
        <Label x:Name="dateLabel" HorizontalTextAlignment="Start" />

    </VerticalStackLayout>
</ContentView>
