<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.democratia.Views.Component.DecideurIndicator"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">

    <HorizontalStackLayout Spacing="{StaticResource SpacingVerySmall}">

        <Ellipse
            Fill="{Binding CouleurCercle, Source={x:Reference this}}"
            HeightRequest="{StaticResource SpacingLarge}"
            WidthRequest="{StaticResource SpacingLarge}" />

        <Label
            Style="{StaticResource LabelStyle}"
            Text="{Binding Texte, Source={x:Reference this}}"
            VerticalOptions="Center" />

    </HorizontalStackLayout>

</ContentView>