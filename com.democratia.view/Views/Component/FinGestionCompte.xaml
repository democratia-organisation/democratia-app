<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.democratia.Views.Component.FinGestionCompte"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">

    <StackLayout Spacing="{DynamicResource SpacingLarge}">
        <Label
            x:Name="suiteActionLabel"
            AutomationId="supprimerLabel"
            HorizontalOptions="Center"
            Style="{StaticResource SubHeadlineStyle}"
            Text="{Binding LabelText, Source={x:Reference this}}"
            VerticalOptions="Center" />
        <Button
            x:Name="suiteActionButton"
            AutomationId="suiteActionButton"
            Command="{Binding Command, Source={x:Reference this}}"
            CommandParameter="{Binding CommandParameter, Source={x:Reference this}}"
            HorizontalOptions="Center"
            Style="{StaticResource ButtonStyle}"
            Text="{Binding ButtonText, Source={x:Reference this}}"
            VerticalOptions="Center" />
    </StackLayout>

</ContentView>