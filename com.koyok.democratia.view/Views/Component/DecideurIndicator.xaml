<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.koyok.democratia.UI.Component.DecideurIndicator"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">

    <HorizontalStackLayout x:Name="mainLayout" Spacing="{StaticResource SpacingVerySmall}">

        <Ellipse
            x:Name="rondIndicateurEllipse"
            AutomationId="rondIndicateurEllipse"
            Fill="{Binding CouleurCercle, Source={x:Reference this}}"
            HeightRequest="{StaticResource SpacingLarge}"
            WidthRequest="{StaticResource SpacingLarge}" />

        <Label
            x:Name="texteLabel"
            AutomationId="texteLabel"
            Style="{StaticResource LabelStyle}"
            Text="{Binding Texte, Source={x:Reference this}}"
            VerticalOptions="Center" />

    </HorizontalStackLayout>

</ContentView>