<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.koyok.democratia.UI.Component.LoadingComponent"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.koyok.democratia.UI.Component">

    <Grid>
        <component:LoadingArc
            x:Name="arcPath"
            AutomationId="arcPath"
            Couleur="{AppThemeBinding Light={DynamicResource Light-secondaryFixed},
                                      Dark={DynamicResource Dark-secondaryFixed}}" />
        <component:LoadingArc
            x:Name="arcBisPath"
            AutomationId="arcBisPath"
            Couleur="{AppThemeBinding Light={DynamicResource Light-secondary},
                                      Dark={DynamicResource Dark-secondary}}" />
    </Grid>

</ContentView>