<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.koyok.democratia.UI.Component.LoadingComponent"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">

    <Ellipse
        x:Name="arcPath"
        HeightRequest="100"
        Stroke="{AppThemeBinding Light={DynamicResource Light-tertiary},
                                 Dark={DynamicResource Dark-tertiary}}"
        StrokeThickness="10"
        WidthRequest="100" />
</ContentView>