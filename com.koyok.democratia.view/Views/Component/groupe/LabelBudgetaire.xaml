<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="com.koyok.democratia.UI.Component.groupe.LabelBudgetaire"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="this">

    <Border
        x:Name="mainBorder"
        Stroke="{AppThemeBinding Light={StaticResource Light-primaryContainer},
                                 Dark={StaticResource Dark-primaryContainer}}"
        StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="50" />
        </Border.StrokeShape>

        <HorizontalStackLayout x:Name="labelBudgetaireLayout" BackgroundColor="{AppThemeBinding Light={StaticResource Light-surfaceVariant}, Dark={StaticResource Dark-surfaceVariant}}">

            <Label
                x:Name="titleLabel"
                AutomationId="titleLabel"
                HorizontalOptions="Center"
                Style="{StaticResource LabelStyle}"
                Text="{Binding Title, Source={x:Reference this}}"
                VerticalOptions="Center" />


            <Entry
                x:Name="budgetEntry"
                AutomationId="budgetEntry"
                HorizontalOptions="Center"
                Keyboard="Numeric"
                MaximumWidthRequest="100"
                Style="{StaticResource EntryStyle}"
                Text="{Binding Texte, Source={x:Reference this}, Mode=TwoWay}"
                TextChanged="OnEntryTextChanged"
                VerticalOptions="Center" />


        </HorizontalStackLayout>
    </Border>
</ContentView>