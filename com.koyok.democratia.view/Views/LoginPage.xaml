<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="com.koyok.democratia.UI.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.koyok.democratia.UI.Component"
    xmlns:converters="clr-namespace:com.koyok.democratia.Domain.Extension;assembly=com.koyok.democratia.core"
    xmlns:lang="clr-namespace:com.koyok.democratia.view.Resources.Localization"
    xmlns:local="clr-namespace:com.koyok.democratia.UI"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModels="clr-namespace:com.koyok.democratia.UI;assembly=com.koyok.democratia.core"
    Title="LoginPage"
    x:DataType="viewModels:LoginViewModel"
    AutomationId="loginPage"
    Style="{DynamicResource fondEcran}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToBoolConverter x:Key="StringToBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>
    <VerticalStackLayout Spacing="{DynamicResource SpacingMedium}">

        <Label
            x:Name="connexionLabel"
            AutomationId="connexionLabel"
            HorizontalOptions="Center"
            Style="{DynamicResource HeadlineStyle}"
            Text="{x:Static lang:AppResources.Identifiant}" />

        <component:EntryComponent
            x:Name="mailEntryComponent"
            Title="{x:Static lang:AppResources.mail}"
            AutomationId="mailEntryComponent"
            ValeurDonne="{Binding adresseMail}" />

        <component:EntryComponent
            x:Name="passwordEntryComponent"
            Title="{x:Static lang:AppResources.Mdp}"
            AutomationId="passwordEntryComponent"
            PassWord="True"
            ValeurDonne="{Binding motDePasse}" />

        <Label
            x:Name="errorMessageLabel"
            AutomationId="errorMessageLabel"
            HorizontalOptions="Center"
            Style="{DynamicResource ErrorLabelStyle}"
            Text="{Binding errorMessage}" />

        <HorizontalStackLayout
            HorizontalOptions="Center"
            Spacing="{DynamicResource SpacingMedium}"
            VerticalOptions="End">
            <Label
                x:Name="pasDeCompteLabel"
                AutomationId="pasDeCompteLabel"
                HorizontalOptions="Center"
                Style="{DynamicResource LabelStyle}"
                Text="{x:Static lang:AppResources.pasCompte}" />

            <Label
                x:Name="creationCompteLabelButton"
                AutomationId="creationCompteLabelButton"
                HorizontalOptions="Center"
                Style="{DynamicResource LabelStyle}"
                Text="{x:Static lang:AppResources.NewCompte}"
                TextColor="{AppThemeBinding Light={DynamicResource Light-tertiary},
                                            Dark={DynamicResource Dark-tertiary}}"
                TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateTappedCommand}" CommandParameter="CreationPage" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <Button
            x:Name="seConnecterButton"
            AutomationId="seConnecterButton"
            Command="{Binding NavigateTappedCommand}"
            CommandParameter="/HomePage"
            Style="{DynamicResource ButtonStyle}"
            Text="{x:Static lang:AppResources.connecter}"
            VerticalOptions="End" />
    </VerticalStackLayout>
</ContentPage>
