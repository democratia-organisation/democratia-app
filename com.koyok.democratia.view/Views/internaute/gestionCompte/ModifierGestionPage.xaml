<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="com.koyok.democratia.UI.internaute.gestionCompte.ModifierGestionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.koyok.democratia.UI.Component.internaute"
    xmlns:lang="clr-namespace:com.koyok.democratia.view.Resources.Localization"
    xmlns:viewModel="clr-namespace:com.koyok.democratia.UI.internaute.gestionCompte;assembly=com.koyok.democratia.core"
    Title="ModifierGestionPage"
    x:DataType="viewModel:ModifierGestionViewModel"
    AutomationId="modifierGestionPage"
    Style="{DynamicResource fondEcran}">

    <component:Formulaire
        x:Name="formulaireComponent"
        ActionTappedCommand="{Binding ModifierInternauteCommand}"
        AutomationId="formulaireComponent"
        RetourMessage="{Binding retourMessage}"
        TextAction="{x:Static lang:AppResources.enregistrer}"
        User="{Binding tempInternaute}" />
</ContentPage>