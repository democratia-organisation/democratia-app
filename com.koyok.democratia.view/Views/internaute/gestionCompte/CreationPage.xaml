<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="com.koyok.democratia.UI.internaute.gestionCompte.CreationPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.koyok.democratia.UI.Component"
    xmlns:lang="clr-namespace:com.koyok.democratia.view.Resources.Localization"
    xmlns:local="clr-namespace:com.koyok.democratia.UI"
    xmlns:viewModel="clr-namespace:com.koyok.democratia.UI.internaute.gestionCompte;assembly=com.koyok.democratia.core"
    x:DataType="viewModel:CreationViewModel"
    AutomationId="creationPage"
    Style="{DynamicResource fondEcran}">

    <component:Formulaire
        x:Name="formulaireComponent"
        ActionTappedCommand="{Binding CreerInternauteTappedCommand}"
        AutomationId="formulaireComponent"
        RetourMessage="{Binding retourMessage}"
        TextAction="{x:Static lang:AppResources.inscription}"
        User="{Binding internaute}" />
</ContentPage>
