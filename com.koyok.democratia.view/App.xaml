<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="com.koyok.democratia.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:component="clr-namespace:com.koyok.democratia.Views.Component"
    xmlns:local="clr-namespace:com.koyok.democratia">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/Dark.xaml" />
                <ResourceDictionary Source="/Resources/Styles/Light.xaml" />
                <ResourceDictionary Source="/Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="/Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="/Resources/Dimension/Dimension.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <ControlTemplate x:Key="PageTemplate">
                <Grid RowDefinitions="Auto, *">
                    <component:Header Grid.Row="0" />

                    <ContentPresenter Grid.Row="1" />
                </Grid>
            </ControlTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>